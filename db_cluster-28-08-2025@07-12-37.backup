--
-- Name: export_v_time_lines; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.export_v_time_lines AS
 SELECT l.batch_id,
    l.entity_id AS time_entry_id,
    u.full_name AS employee,
    u.email AS employee_email,
    c.name AS client,
    p.name AS project,
    l.work_date,
    l.minutes,
    round(((l.minutes)::numeric / 60.0), 2) AS hours,
    l.rate,
    round((((l.minutes)::numeric / 60.0) * COALESCE(l.rate, (0)::numeric)), 2) AS amount
   FROM (((public.export_lines l
     LEFT JOIN public.users u ON ((u.id = l.user_id)))
     LEFT JOIN public.clients c ON ((c.id = l.client_id)))
     LEFT JOIN public.projects p ON ((p.id = l.project_id)))
  WHERE (l.entity_type = 'time_entry'::text);


ALTER VIEW public.export_v_time_lines OWNER TO postgres;

