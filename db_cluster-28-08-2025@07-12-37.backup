--
-- Name: users Users can manage own data; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage own data" ON public.users USING ((auth.uid() = id));


--
-- Name: time_entries Users can manage own time entries; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage own time entries" ON public.time_entries USING ((auth.uid() = ( SELECT timesheets.user_id
   FROM public.timesheets
  WHERE (timesheets.id = time_entries.timesheet_id))));


--
-- Name: timesheets Users can manage own timesheets; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage own timesheets" ON public.timesheets USING ((auth.uid() = user_id));


